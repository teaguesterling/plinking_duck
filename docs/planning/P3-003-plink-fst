## Testing

### Positive Tests

```sql
require plinking_duck

# Two populations, known genotypes
query TTTTTRI
SELECT CHROM, POS, ID, REF, ALT, ROUND(FST, 4), OBS_CT
FROM plink_fst('test/data/pgen_example.pgen',
    populations := ['POP_A', 'POP_A', 'POP_B', 'POP_B'])
ORDER BY ID;
----
(validated against plink2 --fst output)

# Row count matches variant count
query I
SELECT COUNT(*)
FROM plink_fst('test/data/pgen_example.pgen',
    populations := ['POP_A', 'POP_A', 'POP_B', 'POP_B']);
----
4

# FST between identical populations should be ~0
# (same population labeled as two groups)
query I
SELECT COUNT(*) FROM plink_fst('test/data/pgen_example.pgen',
    populations := ['A', 'A', 'A', 'A'])
WHERE ABS(FST) > 0.001;
----
0

# Region filtering
query I
SELECT COUNT(*)
FROM plink_fst('test/data/large_example.pgen',
    populations := ['A','A','A','A','B','B','B','B'],
    region := '1');
----
1000
```

### Negative Tests

```sql
require plinking_duck

# Missing populations parameter
statement error
SELECT * FROM plink_fst('test/data/pgen_example.pgen');
----
populations parameter is required

# Population length mismatch
statement error
SELECT * FROM plink_fst('test/data/pgen_example.pgen',
    populations := ['A', 'B']);
----
population label count

# Only one population
statement error
SELECT * FROM plink_fst('test/data/pgen_example.pgen',
    populations := ['A', 'A', 'A', 'A']);
----
at least two populations
```

