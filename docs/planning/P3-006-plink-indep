## Testing

### Positive Tests

```sql
require plinking_duck

# Row count matches variant count (all variants reported)
query I
SELECT COUNT(*) FROM plink_indep('test/data/pgen_example.pgen');
----
4

# At least some variants kept
query I
SELECT COUNT(*) FROM plink_indep('test/data/pgen_example.pgen')
WHERE STATUS = 'in';
----
(> 0)

# in + out = total
query I
SELECT COUNT(*) FILTER (WHERE STATUS = 'in')
     + COUNT(*) FILTER (WHERE STATUS = 'out')
FROM plink_indep('test/data/pgen_example.pgen');
----
4

# Strict threshold prunes more
query B
SELECT (SELECT COUNT(*) FILTER (WHERE STATUS = 'in')
        FROM plink_indep('test/data/large_example.pgen', r2_threshold := 0.1))
    <= (SELECT COUNT(*) FILTER (WHERE STATUS = 'in')
        FROM plink_indep('test/data/large_example.pgen', r2_threshold := 0.5));
----
true

# Validate against plink2 --indep-pairwise output
query T rowsort
SELECT ID FROM plink_indep('test/data/pgen_example.pgen',
    window_size := 50, step := 5, r2_threshold := 0.5)
WHERE STATUS = 'in';
----
(validated against plink2 .prune.in)
```

### Negative Tests

```sql
require plinking_duck

# Invalid r² threshold
statement error
SELECT * FROM plink_indep('test/data/pgen_example.pgen',
    r2_threshold := 1.5);
----
(error)

# Negative window size
statement error
SELECT * FROM plink_indep('test/data/pgen_example.pgen',
    window_size := -1);
----
(error)
```

