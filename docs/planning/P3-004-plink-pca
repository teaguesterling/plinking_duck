## Testing

### Positive Tests

```sql
require plinking_duck

# Row count matches sample count
query I
SELECT COUNT(*) FROM plink_pca('test/data/pgen_example.pgen');
----
4

# Default returns 10 PCs (or sample_ct - 1 if fewer samples)
# With 4 samples, expect 3 PCs
query I
SELECT COUNT(COLUMNS(*)) - 2
FROM plink_pca('test/data/pgen_example.pgen');
----
3

# PCs are orthogonal (dot product ≈ 0)
# Validate via plink2 --pca output comparison

# Eigenvalue mode
query I
SELECT COUNT(*) FROM plink_pca('test/data/pgen_example.pgen',
    output := 'eigenvalues');
----
3

# Eigenvalues are non-negative and decreasing
query I
SELECT COUNT(*) FROM (
    SELECT EIGENVALUE, LAG(EIGENVALUE) OVER (ORDER BY PC) AS prev_ev
    FROM plink_pca('test/data/pgen_example.pgen', output := 'eigenvalues')
) WHERE prev_ev IS NOT NULL AND EIGENVALUE > prev_ev;
----
0
```

### Negative Tests

```sql
require plinking_duck

# No .psam (required for sample IDs)
statement error
SELECT * FROM plink_pca('test/data/pgen_orphan.pgen');
----
(error)

# n_pcs > sample_ct
statement error
SELECT * FROM plink_pca('test/data/pgen_example.pgen', n_pcs := 100);
----
(error: n_pcs exceeds)
```

