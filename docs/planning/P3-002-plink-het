## Testing

### Positive Tests

```sql
require plinking_duck

# Row count matches sample count
query I
SELECT COUNT(*) FROM plink_het('test/data/pgen_example.pgen');
----
4

# F coefficient between -1 and 1
query I
SELECT COUNT(*) FROM plink_het('test/data/pgen_example.pgen')
WHERE F < -1.0 OR F > 1.0;
----
0

# O_HET + O_HOM = N_NM
query I
SELECT COUNT(*) FROM plink_het('test/data/pgen_example.pgen')
WHERE O_HET + O_HOM != N_NM;
----
0

# Validate against plink2 --het output
query TTRIRRI rowsort
SELECT IID, FID, O_HOM, ROUND(E_HOM, 2), N_NM, O_HET, ROUND(F, 4)
FROM plink_het('test/data/pgen_example.pgen');
----
(validated against plink2 output)
```

### Negative Tests

```sql
require plinking_duck

# File not found
statement error
SELECT * FROM plink_het('nonexistent.pgen');
----
(error)

# No .psam file (required for sample IDs)
statement error
SELECT * FROM plink_het('test/data/pgen_orphan.pgen');
----
(error: psam required)
```

