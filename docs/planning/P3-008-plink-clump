## Testing

### Positive Tests

```sql
require plinking_duck

# Known clumping result
query TTTRI
SELECT CHROM, POS, ID, ROUND(P, 8), NSIG
FROM plink_clump('test/data/pgen_example.pgen',
    pvalues := [
        {'id': 'rs1', 'p': 1e-10},
        {'id': 'rs2', 'p': 1e-5},
        {'id': 'rs3', 'p': 0.001},
        {'id': 'rs4', 'p': 0.5}
    ],
    p1 := 1e-4, p2 := 0.01)
ORDER BY P;
----
(validated against plink2 --clump output)

# Stricter threshold produces fewer clumps
query I
SELECT COUNT(*) FROM plink_clump('test/data/pgen_example.pgen',
    pvalues := [...], p1 := 1e-20);
----
(≤ count with p1 := 1e-4)

# All index variants have p < p1
query I
SELECT COUNT(*) FROM plink_clump('test/data/pgen_example.pgen',
    pvalues := [...], p1 := 1e-4)
WHERE P >= 1e-4;
----
0
```

### Negative Tests

```sql
require plinking_duck

# Missing pvalues parameter
statement error
SELECT * FROM plink_clump('test/data/pgen_example.pgen');
----
pvalues parameter is required

# Empty pvalues list
statement error
SELECT * FROM plink_clump('test/data/pgen_example.pgen',
    pvalues := []);
----
(error)

# Invalid threshold
statement error
SELECT * FROM plink_clump('test/data/pgen_example.pgen',
    pvalues := [{'id': 'rs1', 'p': 0.01}],
    p1 := -1.0);
----
(error)
```

