## SQL Interface

```sql
-- Clump from plink_glm results (composable)
SELECT * FROM plink_clump('data/cohort.pgen',
    pvalues := (SELECT list({'id': ID, 'p': P})
                FROM plink_glm('data/cohort.pgen',
                    phenotype := getvariable('pheno'))
                WHERE P < 0.01));

-- Clump from external summary statistics
SET VARIABLE pvals = (SELECT list({'id': ID, 'p': P})
    FROM read_csv('gwas_results.tsv', columns := {'ID': 'VARCHAR', 'P': 'DOUBLE'}));
SELECT * FROM plink_clump('data/reference.pgen',
    pvalues := getvariable('pvals'));

-- Custom clumping parameters
SELECT * FROM plink_clump('data/cohort.pgen',
    pvalues := getvariable('pvals'),
    p1 := 5e-8,           -- index variant p-value threshold
    p2 := 1e-4,           -- clump member p-value threshold
    r2_threshold := 0.1,  -- LD threshold for clumping
    window_kb := 250);    -- clump window

-- Only index variants (one per locus)
SELECT CHROM, POS, ID, P, SP2
FROM plink_clump('data/cohort.pgen',
    pvalues := getvariable('pvals'))
ORDER BY P;
```

