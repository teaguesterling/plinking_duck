## Testing

### Positive Tests

```sql
require plinking_duck

# Known kinship for identical samples
# (duplicate sample should have kinship ≈ 0.5)

# All kinship values in valid range
query I
SELECT COUNT(*) FROM plink_king('test/data/pgen_example.pgen',
    min_kinship := -1.0)
WHERE KINSHIP < -0.5 OR KINSHIP > 0.5;
----
0

# NSNP consistent across pairs
query I
SELECT COUNT(DISTINCT NSNP) FROM plink_king('test/data/pgen_example.pgen',
    min_kinship := -1.0);
----
(expected: 1 if no missing data, >1 with missingness)

# Validate against plink2 --make-king-table output
query TTTTIRR rowsort
SELECT IID1, FID1, IID2, FID2, NSNP, ROUND(IBS0, 4), ROUND(KINSHIP, 4)
FROM plink_king('test/data/pgen_example.pgen', min_kinship := -1.0)
ORDER BY IID1, IID2;
----
(validated against plink2 output)
```

### Negative Tests

```sql
require plinking_duck

# No .psam (required for sample IDs)
statement error
SELECT * FROM plink_king('test/data/pgen_orphan.pgen');
----
(error)

# Only one sample
statement error
SELECT * FROM plink_king('test/data/pgen_example.pgen',
    samples := ['SAMPLE1']);
----
(error: need at least 2 samples)
```

