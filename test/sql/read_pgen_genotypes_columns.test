# name: test/sql/read_pgen_genotypes_columns.test
# description: Positive tests for read_pgen genotypes := 'columns' mode
# group: [sql]

require plinking_duck

# ===================================================================
# Basic: 4 samples → 4 TINYINT columns
# ===================================================================

query I
SELECT COUNT(*) FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns');
----
4

# Type check
query TT
SELECT typeof(SAMPLE1), typeof(SAMPLE2)
FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns') LIMIT 1;
----
TINYINT	TINYINT

# rs1: [0, 1, 2, NULL]
query TIIII
SELECT ID, SAMPLE1, SAMPLE2, SAMPLE3, SAMPLE4
FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns')
WHERE ID = 'rs1';
----
rs1	0	1	2	NULL

# rs2: [1, 1, 0, 2]
query TIIII
SELECT ID, SAMPLE1, SAMPLE2, SAMPLE3, SAMPLE4
FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns')
WHERE ID = 'rs2';
----
rs2	1	1	0	2

# ===================================================================
# With sample subset
# ===================================================================

query III
SELECT ID, SAMPLE1, SAMPLE3
FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns',
               samples := ['SAMPLE1', 'SAMPLE3'])
WHERE ID = 'rs1';
----
rs1	0	2

query III
SELECT ID, SAMPLE1, SAMPLE3
FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns',
               samples := ['SAMPLE1', 'SAMPLE3'])
WHERE ID = 'rs3';
----
rs3	2	1

# ===================================================================
# Projection pushdown: metadata only
# ===================================================================

query TI
SELECT CHROM, POS FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'columns') ORDER BY CHROM, POS;
----
1	10000
1	20000
1	30000
2	15000

# ===================================================================
# NULL handling: all_missing dataset
# ===================================================================

query III
SELECT ID, SAMPLE1, SAMPLE2
FROM read_pgen('test/data/all_missing.pgen', genotypes := 'columns') ORDER BY POS;
----
rs_miss1	NULL	NULL
rs_miss2	NULL	NULL
