# name: test/sql/plink_glm.test
# description: Test plink_glm regression (validated against plink2 --glm)
# group: [plinking_duck]

require plinking_duck

# ===========================================================================
# Phase 1: Linear regression, no covariates
# Reference: plink2 --pfile pgen_example --pheno pheno.tsv --glm allow-no-covars
# ===========================================================================

# Full output with all columns (OR and FIRTH_YN are NULL for linear)
query TIITTTRTIRRRRTRT
SELECT CHROM, POS, ID, REF, ALT, A1, A1_FREQ, TEST, OBS_CT, BETA, SE, T_STAT, P, ERRCODE, "OR", FIRTH_YN
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, 2.3, 3.7, 0.8])
ORDER BY ID;
----
1	10000	rs1	A	G	G	0.5	ADD	3	1.1	0.17320508075688776	6.350852961085884	0.09942530566691602	NULL	NULL	NULL
1	20000	rs2	C	T	T	0.5	ADD	4	-1.45	0.33260250429475794	-4.359548017600793	0.04879676508539067	NULL	NULL	NULL
1	30000	rs3	G	A	A	0.5	ADD	3	0.3500000000000001	1.4722431864335457	0.23773160637676483	0.8514126919174483	NULL	NULL	NULL
2	15000	rs4	T	C	C	0.375	ADD	4	-0.33636363636363636	0.8879360193399447	-0.37881508091390906	0.7412587024131992	NULL	NULL	NULL

# Row count matches variant count
query I
SELECT COUNT(*)
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, 2.3, 3.7, 0.8]);
----
4

# ---------------------------------------------------------------------------
# Region filtering
# ---------------------------------------------------------------------------

query I
SELECT COUNT(*)
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, 2.3, 3.7, 0.8],
    region := '1:1-100000');
----
3

query I
SELECT COUNT(*)
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, 2.3, 3.7, 0.8],
    region := '2:1-100000');
----
1

# ---------------------------------------------------------------------------
# Phenotype via SET VARIABLE (getvariable workflow)
# ---------------------------------------------------------------------------

statement ok
SET VARIABLE pheno = [1.5, 2.3, 3.7, 0.8];

query TR
SELECT ID, ROUND(BETA, 4)
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := getvariable('pheno'))
ORDER BY ID;
----
rs1	1.1
rs2	-1.45
rs3	0.35
rs4	-0.3364

# ---------------------------------------------------------------------------
# Projection pushdown (only metadata columns)
# ---------------------------------------------------------------------------

query TI
SELECT ID, POS
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, 2.3, 3.7, 0.8])
ORDER BY ID;
----
rs1	10000
rs2	20000
rs3	30000
rs4	15000

# ---------------------------------------------------------------------------
# Large dataset (3000 variants × 8 samples)
# ---------------------------------------------------------------------------

query I
SELECT COUNT(*)
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1.2, 3.4, 2.1, 5.6, 4.3, 0.9, 3.8, 2.7]);
----
3000

# Region filter on large dataset
query I
SELECT COUNT(*)
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1.2, 3.4, 2.1, 5.6, 4.3, 0.9, 3.8, 2.7],
    region := '1:1-500');
----
5

# Validate first variant of large dataset against plink2
query TRRIR
SELECT ID, ROUND(A1_FREQ, 4), OBS_CT, ROUND(BETA, 6), ROUND(SE, 6)
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1.2, 3.4, 2.1, 5.6, 4.3, 0.9, 3.8, 2.7])
WHERE ID = 'var1';
----
var1	0.5	6	-1.0	0.878505

# ---------------------------------------------------------------------------
# Composability with other functions
# ---------------------------------------------------------------------------

query TRR
SELECT g.ID, ROUND(g.P, 6) as P, ROUND(f.ALT_FREQ, 4) as ALT_FREQ
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, 2.3, 3.7, 0.8]) g
JOIN plink_freq('test/data/pgen_example.pgen') f ON g.ID = f.ID
WHERE g.P < 0.1
ORDER BY g.P;
----
rs2	0.04880	0.5
rs1	0.099425	0.5

# ---------------------------------------------------------------------------
# NULL phenotype values (missing samples excluded from regression)
# ---------------------------------------------------------------------------

query TIRT
SELECT ID, OBS_CT, ROUND(BETA, 4), ERRCODE
FROM plink_glm('test/data/pgen_example.pgen',
    phenotype := [1.5, NULL, 3.7, 0.8])
ORDER BY ID;
----
rs1	2	NULL	TOO_FEW_SAMPLES
rs2	3	-1.45	NULL
rs3	3	0.35	NULL
rs4	3	-0.35	NULL

# ===========================================================================
# Phase 2: Covariates
# ===========================================================================

# Linear with 1 covariate (large_example, 8 samples)
query TRRRI
SELECT ID, ROUND(BETA, 6), ROUND(SE, 6), ROUND(P, 6), OBS_CT
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1.2, 3.4, 2.1, 5.6, 4.3, 0.9, 3.8, 2.7],
    covariates := {'age': [25.0, 30.0, 35.0, 40.0, 45.0, 50.0, 55.0, 60.0]})
WHERE ID = 'var1';
----
var1	-1.120455	1.062566	0.369083	6

# Linear with 2 covariates
query TRRR
SELECT ID, ROUND(BETA, 6), ROUND(SE, 6), ROUND(P, 6)
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1.2, 3.4, 2.1, 5.6, 4.3, 0.9, 3.8, 2.7],
    covariates := {'age': [25.0, 30.0, 35.0, 40.0, 45.0, 50.0, 55.0, 60.0],
                   'bmi': [22.1, 24.5, 23.0, 28.3, 26.1, 21.5, 25.8, 23.2]})
WHERE ID = 'var1';
----
var1	0.020132	0.247427	0.942561

# ===========================================================================
# Phase 2: Logistic regression (auto-detection of binary phenotype)
# ===========================================================================

# Binary 0/1 phenotype → auto-detects logistic
# plink2's LogisticRegressionF converges for balanced phenotypes, so no Firth needed
query TRRRT
SELECT ID, ROUND(BETA, 6), ROUND(SE, 6), ROUND("OR", 6), FIRTH_YN
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 1, 1, 0, 1, 0])
WHERE ID = 'var1';
----
var1	0.0	1.0	1.0	N

# Binary 1/2 phenotype → auto-remaps to 0/1, uses logistic
query TRRRT
SELECT ID, ROUND(BETA, 6), ROUND(SE, 6), ROUND("OR", 6), FIRTH_YN
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1, 2, 1, 2, 2, 1, 2, 1])
WHERE ID = 'var1';
----
var1	0.0	1.0	1.0	N

# Logistic with correlated phenotype (non-trivial result)
# plink2's FirthRegressionF uses different variance-covariance than our old impl
query TRRRRRT
SELECT ID, ROUND(BETA, 6), ROUND(SE, 6), ROUND(T_STAT, 6), ROUND(P, 6), ROUND("OR", 6), FIRTH_YN
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 0, 1, 1, 0, 0])
WHERE ID = 'var1';
----
var1	1.855205	1.248652	1.485766	0.137341	6.393007	Y

# Row count for logistic
query I
SELECT COUNT(*)
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 1, 1, 0, 1, 0]);
----
3000

# ===========================================================================
# Phase 2: Firth correction
# ===========================================================================

# Without Firth, convergence fails (var1 with correlated phenotype)
# plink2's LogisticRegressionF hits iteration limit (is_unfinished) rather
# than hard-failing, so we report NO_CONVERGENCE instead of SEPARATION
query TRT
SELECT ID, BETA, ERRCODE
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 0, 1, 1, 0, 0],
    firth := false)
WHERE ID = 'var1';
----
var1	NULL	NO_CONVERGENCE

# With Firth (default), the same variant converges
query TRRT
SELECT ID, ROUND(BETA, 4), ROUND("OR", 4), FIRTH_YN
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 0, 1, 1, 0, 0])
WHERE ID = 'var1';
----
var1	1.8552	6.393	Y

# Firth disabled explicitly: FIRTH_YN = N for converged variants
query TRT
SELECT ID, ROUND("OR", 6), FIRTH_YN
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 1, 1, 0, 1, 0],
    firth := false)
WHERE ID = 'var1';
----
var1	1.0	N

# ===========================================================================
# Phase 2: Model parameter override
# ===========================================================================

# Force linear on binary phenotype (OR and FIRTH_YN are NULL)
query TRTT
SELECT ID, ROUND(BETA, 6), "OR", FIRTH_YN
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [0, 1, 0, 1, 1, 0, 1, 0],
    model := 'linear')
WHERE ID = 'var1';
----
var1	0.0	NULL	NULL

# Force logistic on continuous phenotype → NO_CONVERGENCE
query TT
SELECT ID, ERRCODE
FROM plink_glm('test/data/large_example.pgen',
    phenotype := [1.2, 3.4, 2.1, 5.6, 4.3, 0.9, 3.8, 2.7],
    model := 'logistic')
WHERE ID = 'var1';
----
var1	NO_CONVERGENCE
