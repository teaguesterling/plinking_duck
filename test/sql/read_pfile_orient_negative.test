# name: test/sql/read_pfile_orient_negative.test
# description: Negative tests for orient parameter
# group: [sql]

require plinking_duck

# --- Invalid orient value ---

statement error
SELECT * FROM read_pfile('test/data/pfile_example', orient := 'invalid');
----
invalid orient value 'invalid'

# --- orient := 'sample' on read_pgen (not supported) ---

statement error
SELECT * FROM read_pgen('test/data/pgen_example.pgen', orient := 'sample');
----
orient := 'sample' is not supported

# --- orient := 'genotype' on read_pgen (not supported) ---

statement error
SELECT * FROM read_pgen('test/data/pgen_example.pgen', orient := 'genotype');
----
orient := 'genotype' is not supported

# --- plinking_max_matrix_elements config option ---

# Setting the limit very low triggers the guard
statement ok
SET plinking_max_matrix_elements = 1;

statement error
SELECT * FROM read_pfile('test/data/pfile_example', orient := 'sample');
----
would require 16 genotype values

# Restoring a reasonable limit allows it to succeed
statement ok
SET plinking_max_matrix_elements = 1000;

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', orient := 'sample');
----
4
