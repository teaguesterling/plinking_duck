# name: test/sql/read_pfile_genotypes_stats.test
# description: Test genotypes := 'stats' mode for read_pfile and read_pgen
# group: [plinking_duck]

require plinking_duck

# --- Variant orient: STATS mode ---

# Basic STATS output - check counts + derived fields
# rs1: hom_ref=1, het=1, hom_alt=1, missing=1 -> n=3, af=(1+2)/6=0.5, maf=0.5
# rs2: hom_ref=1, het=2, hom_alt=1, missing=0 -> n=4, af=(2+2)/8=0.5, maf=0.5
# rs3: hom_ref=1, het=1, hom_alt=1, missing=1 -> n=3, af=(1+2)/6=0.5, maf=0.5
# rs4: hom_ref=2, het=1, hom_alt=1, missing=0 -> n=4, af=(1+2)/8=0.375, maf=0.375

query IIIIIRRRII
SELECT genotypes.hom_ref,
       genotypes.het,
       genotypes.hom_alt,
       genotypes.missing,
       genotypes.n,
       ROUND(genotypes.af, 6) AS af,
       ROUND(genotypes.maf, 6) AS maf,
       ROUND(genotypes.missing_rate, 6) AS missing_rate,
       genotypes.carrier_count,
       ROUND(genotypes.het_rate, 6) AS het_rate
FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
ORDER BY ID;
----
1	1	1	1	3	0.5	0.5	0.25	2	0.333333
1	2	1	0	4	0.5	0.5	0.0	3	0.5
1	1	1	1	3	0.5	0.5	0.25	2	0.333333
2	1	1	0	4	0.375	0.375	0.0	2	0.25

# Verify column type
query T
SELECT typeof(genotypes)
FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
LIMIT 1;
----
STRUCT(hom_ref UINTEGER, het UINTEGER, hom_alt UINTEGER, missing UINTEGER, n UINTEGER, af DOUBLE, maf DOUBLE, missing_rate DOUBLE, carrier_count UINTEGER, het_rate DOUBLE)

# --- read_pgen STATS mode ---

query IIIII
SELECT genotypes.hom_ref,
       genotypes.het,
       genotypes.hom_alt,
       genotypes.missing,
       genotypes.n
FROM read_pgen('test/data/pgen_example.pgen', genotypes := 'stats')
ORDER BY ID;
----
1	1	1	1	3
1	2	1	0	4
1	1	1	1	3
2	1	1	0	4

# Cross-check af against plink_freq — values must match exactly
query I
SELECT COUNT(*) FROM (
    SELECT ID, ROUND(genotypes.af, 10) AS af
    FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
    EXCEPT
    SELECT ID, ROUND(ALT_FREQ, 10) AS af
    FROM plink_freq('test/data/pgen_example.pgen')
);
----
0

# Cross-check missing_rate against plink_missing
# plink_missing F_MISS = MISSING_CT / (MISSING_CT + OBS_CT)
# stats missing_rate = missing / (n + missing)
query I
SELECT COUNT(*) FROM (
    SELECT ID, ROUND(genotypes.missing_rate, 10) AS mr
    FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
    EXCEPT
    SELECT ID, ROUND(CAST(MISSING_CT AS DOUBLE) / (MISSING_CT + OBS_CT), 10) AS mr
    FROM plink_missing('test/data/pgen_example.pgen')
);
----
0

# Verify carrier_count = het + hom_alt for each variant
query I
SELECT COUNT(*) FROM (
    SELECT * FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
    WHERE genotypes.carrier_count != genotypes.het + genotypes.hom_alt
);
----
0

# Verify n = hom_ref + het + hom_alt
query I
SELECT COUNT(*) FROM (
    SELECT * FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
    WHERE genotypes.n != genotypes.hom_ref + genotypes.het + genotypes.hom_alt
);
----
0

# Verify maf = min(af, 1-af)
query I
SELECT COUNT(*) FROM (
    SELECT * FROM read_pfile('test/data/pgen_example', genotypes := 'stats')
    WHERE ROUND(genotypes.maf, 10) != ROUND(LEAST(genotypes.af, 1.0 - genotypes.af), 10)
);
----
0

# --- Sample orient STATS mode ---

query TIRRI
SELECT IID,
       genotypes.n,
       ROUND(genotypes.af, 4) AS af,
       ROUND(genotypes.missing_rate, 4) AS mr,
       genotypes.carrier_count
FROM read_pfile('test/data/pgen_example', orient := 'sample', genotypes := 'stats')
ORDER BY IID;
----
SAMPLE1	4	0.375	0.0	2
SAMPLE2	3	0.3333	0.25	2
SAMPLE3	4	0.5	0.0	3
SAMPLE4	3	0.6667	0.25	2

# --- STATS with sample subsetting ---

query IIRR
SELECT genotypes.hom_ref,
       genotypes.het,
       ROUND(genotypes.af, 4) AS af,
       ROUND(genotypes.missing_rate, 4) AS mr
FROM read_pfile('test/data/pgen_example', genotypes := 'stats',
    samples := ['SAMPLE1', 'SAMPLE3'])
ORDER BY ID;
----
1	0	0.5	0.0
1	1	0.25	0.0
0	1	0.75	0.0
1	1	0.25	0.0

# --- STATS with larger dataset ---

query I
SELECT COUNT(*) FROM read_pfile('test/data/large_example', genotypes := 'stats');
----
3000

# All af values in [0, 1]
query I
SELECT COUNT(*) FROM (
    SELECT * FROM read_pfile('test/data/large_example', genotypes := 'stats')
    WHERE genotypes.af < 0.0 OR genotypes.af > 1.0
);
----
0
