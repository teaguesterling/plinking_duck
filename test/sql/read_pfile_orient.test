# name: test/sql/read_pfile_orient.test
# description: Orient parameter tests for read_pfile table function
# group: [sql]

require plinking_duck

# --- orient := 'variant' produces same output as default ---

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', orient := 'variant');
----
4

query TITTT
SELECT CHROM, POS, ID, REF, ALT FROM read_pfile('test/data/pfile_example', orient := 'variant') ORDER BY CHROM, POS;
----
1	10000	rs1	A	G
1	20000	rs2	C	T
1	30000	rs3	G	A
2	15000	rs4	T	C

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', orient := 'variant') WHERE ID = 'rs1';
----
rs1	[0, 1, 2, NULL]

# --- orient := 'genotype' produces same output as tidy := true ---

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', orient := 'genotype');
----
16

query T
SELECT typeof(genotype) FROM read_pfile('test/data/pfile_example', orient := 'genotype') LIMIT 1;
----
TINYINT

query TI
SELECT IID, genotype
FROM read_pfile('test/data/pfile_example', orient := 'genotype')
WHERE ID = 'rs1'
ORDER BY IID;
----
SAMPLE1	0
SAMPLE2	1
SAMPLE3	2
SAMPLE4	NULL

# --- orient := 'sample' basic ---

# Row count = 4 samples
query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', orient := 'sample');
----
4

# --- orient := 'sample' schema check ---

# Sample metadata columns present (FID, IID, SEX from pfile_example.psam)
query TTI
SELECT FID, IID, SEX
FROM read_pfile('test/data/pfile_example', orient := 'sample')
ORDER BY IID
LIMIT 1;
----
FAM001	SAMPLE1	1

# SEX=0 maps to NULL (same as read_psam convention)
query I
SELECT SEX
FROM read_pfile('test/data/pfile_example', orient := 'sample')
WHERE IID = 'SAMPLE3';
----
NULL

# --- orient := 'sample' genotype type = TINYINT[4] (4 effective variants) ---

query T
SELECT typeof(genotypes)
FROM read_pfile('test/data/pfile_example', orient := 'sample') LIMIT 1;
----
TINYINT[4]

query I
SELECT len(genotypes) FROM read_pfile('test/data/pfile_example', orient := 'sample') LIMIT 1;
----
4

# --- orient := 'sample' known genotype values ---

# rs1=[0,1,2,NULL], rs2=[1,1,0,2], rs3=[2,NULL,1,0], rs4=[0,0,1,2]
# So SAMPLE1 across rs1-rs4 = [0, 1, 2, 0]
query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample')
WHERE IID = 'SAMPLE1';
----
SAMPLE1	[0, 1, 2, 0]

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample')
WHERE IID = 'SAMPLE2';
----
SAMPLE2	[1, 1, NULL, 0]

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample')
WHERE IID = 'SAMPLE3';
----
SAMPLE3	[2, 0, 1, 1]

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample')
WHERE IID = 'SAMPLE4';
----
SAMPLE4	[NULL, 2, 0, 2]

# --- orient := 'sample' with sample subsetting ---

query I
SELECT COUNT(*)
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                samples := ['SAMPLE1', 'SAMPLE3']);
----
2

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                samples := ['SAMPLE1', 'SAMPLE3'])
ORDER BY IID;
----
SAMPLE1	[0, 1, 2, 0]
SAMPLE3	[2, 0, 1, 1]

# --- orient := 'sample' with variant filtering (changes array dimension) ---

query T
SELECT typeof(genotypes)
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                variants := ['rs1', 'rs2']) LIMIT 1;
----
TINYINT[2]

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                variants := ['rs1', 'rs2'])
WHERE IID = 'SAMPLE1';
----
SAMPLE1	[0, 1]

# --- orient := 'sample' with region filtering ---

# Region 1:10000-20000 selects rs1 and rs2 (2 variants)
query T
SELECT typeof(genotypes)
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                region := '1:10000-20000') LIMIT 1;
----
TINYINT[2]

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                region := '1:10000-20000')
WHERE IID = 'SAMPLE1';
----
SAMPLE1	[0, 1]

# --- orient := 'sample' combined filters (region + variants + samples) ---

# Region 1:10000-30000 has rs1,rs2,rs3; intersect with variants=['rs1','rs3'] gives rs1,rs3
query I
SELECT COUNT(*)
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                region := '1:10000-30000', variants := ['rs1', 'rs3'],
                samples := ['SAMPLE1']);
----
1

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                region := '1:10000-30000', variants := ['rs1', 'rs3'],
                samples := ['SAMPLE1']);
----
SAMPLE1	[0, 2]

# --- orient := 'sample' + genotypes := 'list' type check ---

query T
SELECT typeof(genotypes)
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                genotypes := 'list') LIMIT 1;
----
TINYINT[]

query TT
SELECT IID, genotypes
FROM read_pfile('test/data/pfile_example', orient := 'sample',
                genotypes := 'list')
WHERE IID = 'SAMPLE1';
----
SAMPLE1	[0, 1, 2, 0]

# --- orient := 'sample' projection pushdown (metadata only, no genotype decode) ---

query TT
SELECT FID, IID
FROM read_pfile('test/data/pfile_example', orient := 'sample')
ORDER BY IID;
----
FAM001	SAMPLE1
FAM001	SAMPLE2
FAM002	SAMPLE3
FAM002	SAMPLE4

# --- tidy := true backward compat (same results as before) ---

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', tidy := true);
----
16

query TI
SELECT IID, genotype
FROM read_pfile('test/data/pfile_example', tidy := true)
WHERE ID = 'rs1'
ORDER BY IID;
----
SAMPLE1	0
SAMPLE2	1
SAMPLE3	2
SAMPLE4	NULL
