# name: test/sql/read_pfile_genotypes_columns.test
# description: Positive tests for read_pfile genotypes := 'columns' mode
# group: [sql]

require plinking_duck

# ===================================================================
# Variant-orient + columns: basic (4 samples → 4 TINYINT cols)
# ===================================================================

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'columns');
----
4

# Column names are sample IIDs
query TTTTTTTTT
SELECT typeof(CHROM), typeof(POS), typeof(ID), typeof(REF), typeof(ALT),
       typeof(SAMPLE1), typeof(SAMPLE2), typeof(SAMPLE3), typeof(SAMPLE4)
FROM read_pfile('test/data/pfile_example', genotypes := 'columns') LIMIT 1;
----
VARCHAR	INTEGER	VARCHAR	VARCHAR	VARCHAR	TINYINT	TINYINT	TINYINT	TINYINT

# rs1: [0, 1, 2, NULL]
query TIIII
SELECT ID, SAMPLE1, SAMPLE2, SAMPLE3, SAMPLE4
FROM read_pfile('test/data/pfile_example', genotypes := 'columns')
WHERE ID = 'rs1';
----
rs1	0	1	2	NULL

# rs2: [1, 1, 0, 2]
query TIIII
SELECT ID, SAMPLE1, SAMPLE2, SAMPLE3, SAMPLE4
FROM read_pfile('test/data/pfile_example', genotypes := 'columns')
WHERE ID = 'rs2';
----
rs2	1	1	0	2

# rs3: [2, NULL, 1, 0]
query TIIII
SELECT ID, SAMPLE1, SAMPLE2, SAMPLE3, SAMPLE4
FROM read_pfile('test/data/pfile_example', genotypes := 'columns')
WHERE ID = 'rs3';
----
rs3	2	NULL	1	0

# rs4: [0, 0, 1, 2]
query TIIII
SELECT ID, SAMPLE1, SAMPLE2, SAMPLE3, SAMPLE4
FROM read_pfile('test/data/pfile_example', genotypes := 'columns')
WHERE ID = 'rs4';
----
rs4	0	0	1	2

# ===================================================================
# Variant-orient + columns + sample subset
# ===================================================================

query II
SELECT SAMPLE1, SAMPLE3
FROM read_pfile('test/data/pfile_example', genotypes := 'columns',
                samples := ['SAMPLE1', 'SAMPLE3'])
WHERE ID = 'rs1';
----
0	2

query II
SELECT SAMPLE1, SAMPLE3
FROM read_pfile('test/data/pfile_example', genotypes := 'columns',
                samples := ['SAMPLE1', 'SAMPLE3'])
WHERE ID = 'rs2';
----
1	0

# ===================================================================
# Sample-orient + columns: basic (4 variants → rs1..rs4 cols)
# ===================================================================

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns');
----
4

# Type check: variant columns are TINYINT
query TT
SELECT typeof(rs1), typeof(rs2)
FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns') LIMIT 1;
----
TINYINT	TINYINT

# SAMPLE1 across variants: rs1=0, rs2=1, rs3=2, rs4=0
query TIIII
SELECT IID, rs1, rs2, rs3, rs4
FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns')
WHERE IID = 'SAMPLE1';
----
SAMPLE1	0	1	2	0

# SAMPLE2: rs1=1, rs2=1, rs3=NULL, rs4=0
query TIIII
SELECT IID, rs1, rs2, rs3, rs4
FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns')
WHERE IID = 'SAMPLE2';
----
SAMPLE2	1	1	NULL	0

# SAMPLE4: rs1=NULL, rs2=2, rs3=0, rs4=2
query TIIII
SELECT IID, rs1, rs2, rs3, rs4
FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns')
WHERE IID = 'SAMPLE4';
----
SAMPLE4	NULL	2	0	2

# ===================================================================
# Sample-orient + columns + variant filter
# ===================================================================

query III
SELECT IID, rs1, rs2
FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns',
                variants := ['rs1', 'rs2'])
WHERE IID = 'SAMPLE1';
----
SAMPLE1	0	1

# ===================================================================
# Sample-orient + columns + region filter
# ===================================================================

# Region 1:10000-20000 selects rs1 and rs2
query III
SELECT IID, rs1, rs2
FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns',
                region := '1:10000-20000')
WHERE IID = 'SAMPLE1';
----
SAMPLE1	0	1

# ===================================================================
# Projection pushdown: metadata only, no genotype decode
# ===================================================================

query TI
SELECT CHROM, POS FROM read_pfile('test/data/pfile_example', genotypes := 'columns') ORDER BY CHROM, POS;
----
1	10000
1	20000
1	30000
2	15000

query TT
SELECT FID, IID FROM read_pfile('test/data/pfile_example', orient := 'sample', genotypes := 'columns') ORDER BY IID;
----
FAM001	SAMPLE1
FAM001	SAMPLE2
FAM002	SAMPLE3
FAM002	SAMPLE4

# ===================================================================
# NULL handling: all_missing dataset
# ===================================================================

query III
SELECT ID, SAMPLE1, SAMPLE2
FROM read_pfile('test/data/all_missing', genotypes := 'columns') ORDER BY POS;
----
rs_miss1	NULL	NULL
rs_miss2	NULL	NULL

# ===================================================================
# Case insensitivity
# ===================================================================

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'COLUMNS');
----
4

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'Columns');
----
4
