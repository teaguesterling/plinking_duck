# name: test/sql/read_pfile_genotypes.test
# description: Positive tests for read_pfile genotypes parameter
# group: [sql]

require plinking_duck

# ===================================================================
# genotypes value: type checks
# ===================================================================

# Default (no param) → ARRAY
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example') LIMIT 1;
----
TINYINT[4]

# Explicit 'auto' → ARRAY for small datasets
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'auto') LIMIT 1;
----
TINYINT[4]

# Explicit 'array'
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'array') LIMIT 1;
----
TINYINT[4]

# Explicit 'list'
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'list') LIMIT 1;
----
TINYINT[]

# ===================================================================
# LIST value correctness
# ===================================================================

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list') WHERE ID = 'rs1';
----
rs1	[0, 1, 2, NULL]

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list') WHERE ID = 'rs2';
----
rs2	[1, 1, 0, 2]

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list') WHERE ID = 'rs3';
----
rs3	[2, NULL, 1, 0]

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list') WHERE ID = 'rs4';
----
rs4	[0, 0, 1, 2]

# ===================================================================
# ARRAY vs LIST equivalence
# ===================================================================

query I
SELECT COUNT(*) FROM (
    SELECT a.ID, a.genotypes::TINYINT[] AS a_geno, l.genotypes AS l_geno
    FROM read_pfile('test/data/pfile_example', genotypes := 'array') a
    JOIN read_pfile('test/data/pfile_example', genotypes := 'list') l ON a.ID = l.ID
    WHERE a_geno != l_geno OR (a_geno IS NULL AND l_geno IS NOT NULL) OR (a_geno IS NOT NULL AND l_geno IS NULL)
);
----
0

# ===================================================================
# genotypes × region filtering
# ===================================================================

# LIST + region: correct count
query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'list', region := '1:10000-20000');
----
2

# LIST + region: type
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'list', region := '1:10000-20000') LIMIT 1;
----
TINYINT[]

# LIST + region: value check
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list', region := '1:10000-20000') ORDER BY POS;
----
rs1	[0, 1, 2, NULL]
rs2	[1, 1, 0, 2]

# ARRAY + region: value check (same results)
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array', region := '1:10000-20000') ORDER BY POS;
----
rs1	[0, 1, 2, NULL]
rs2	[1, 1, 0, 2]

# Chromosome-only region + LIST
query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'list', region := '1');
----
3

# ===================================================================
# genotypes × variants (VARCHAR)
# ===================================================================

# LIST + variants by name
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    variants := ['rs1', 'rs4']) ORDER BY POS;
----
rs1	[0, 1, 2, NULL]
rs4	[0, 0, 1, 2]

query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'list', variants := ['rs2']);
----
1

# ARRAY + variants by name
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array',
    variants := ['rs1', 'rs4']) ORDER BY POS;
----
rs1	[0, 1, 2, NULL]
rs4	[0, 0, 1, 2]

# ===================================================================
# genotypes × variants (integer)
# ===================================================================

# LIST + variants by index
query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'list', variants := [0, 3]);
----
2

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list', variants := [0]) WHERE ID = 'rs1';
----
rs1	[0, 1, 2, NULL]

# ARRAY + variants by index
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array', variants := [0]) WHERE ID = 'rs1';
----
rs1	[0, 1, 2, NULL]

# ===================================================================
# genotypes × samples (integer)
# ===================================================================

# LIST + integer samples: type and length
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'list', samples := [0, 1]) LIMIT 1;
----
TINYINT[]

query I
SELECT len(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'list', samples := [0, 1]) LIMIT 1;
----
2

# LIST + integer samples: values
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list', samples := [0, 1]) WHERE ID = 'rs1';
----
rs1	[0, 1]

# ARRAY + integer samples: type reflects subset
query T
SELECT typeof(genotypes) FROM read_pfile('test/data/pfile_example', genotypes := 'array', samples := [0, 1]) LIMIT 1;
----
TINYINT[2]

# ARRAY + integer samples: values
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array', samples := [0, 1]) WHERE ID = 'rs1';
----
rs1	[0, 1]

# ===================================================================
# genotypes × samples (VARCHAR)
# ===================================================================

# LIST + VARCHAR samples
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    samples := ['SAMPLE1', 'SAMPLE3']) WHERE ID = 'rs1';
----
rs1	[0, 2]

# ARRAY + VARCHAR samples
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array',
    samples := ['SAMPLE1', 'SAMPLE3']) WHERE ID = 'rs1';
----
rs1	[0, 2]

# ARRAY vs LIST equivalence with samples subset
query I
SELECT COUNT(*) FROM (
    SELECT a.ID, a.genotypes::TINYINT[] AS a_geno, l.genotypes AS l_geno
    FROM read_pfile('test/data/pfile_example', genotypes := 'array', samples := ['SAMPLE1', 'SAMPLE3']) a
    JOIN read_pfile('test/data/pfile_example', genotypes := 'list', samples := ['SAMPLE1', 'SAMPLE3']) l ON a.ID = l.ID
    WHERE a_geno != l_geno OR (a_geno IS NULL AND l_geno IS NOT NULL) OR (a_geno IS NOT NULL AND l_geno IS NULL)
);
----
0

# ===================================================================
# genotypes × region × samples (triple combination)
# ===================================================================

# LIST + region + integer samples
query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    region := '1:10000-20000', samples := [0, 2]);
----
2

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    region := '1:10000-20000', samples := [0, 2]) ORDER BY POS;
----
rs1	[0, 2]
rs2	[1, 0]

# ARRAY + region + samples (same values)
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array',
    region := '1:10000-20000', samples := [0, 2]) ORDER BY POS;
----
rs1	[0, 2]
rs2	[1, 0]

# ===================================================================
# genotypes × variants × samples (triple combination)
# ===================================================================

# LIST + variants + samples
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    variants := ['rs1', 'rs4'], samples := ['SAMPLE1', 'SAMPLE3']) ORDER BY POS;
----
rs1	[0, 2]
rs4	[0, 1]

# ARRAY + variants + samples
query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'array',
    variants := ['rs1', 'rs4'], samples := ['SAMPLE1', 'SAMPLE3']) ORDER BY POS;
----
rs1	[0, 2]
rs4	[0, 1]

# ===================================================================
# genotypes × region + variant filter (intersection)
# ===================================================================

# LIST + region + variants intersection
query I
SELECT COUNT(*) FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    region := '1:10000-20000', variants := ['rs1', 'rs3']);
----
1

query TT
SELECT ID, genotypes FROM read_pfile('test/data/pfile_example', genotypes := 'list',
    region := '1:10000-20000', variants := ['rs1', 'rs3']);
----
rs1	[0, 1, 2, NULL]

# ===================================================================
# genotypes × genotype orient mode (silently ignored)
# ===================================================================

# orient := 'genotype' + genotypes := 'list' → still scalar TINYINT
query T
SELECT typeof(genotype) FROM read_pfile('test/data/pfile_example', orient := 'genotype', genotypes := 'list') LIMIT 1;
----
TINYINT

# orient := 'genotype' + genotypes := 'array' → still scalar TINYINT
query T
SELECT typeof(genotype) FROM read_pfile('test/data/pfile_example', orient := 'genotype', genotypes := 'array') LIMIT 1;
----
TINYINT

# orient := 'genotype' + genotypes := 'auto' → still scalar TINYINT
query T
SELECT typeof(genotype) FROM read_pfile('test/data/pfile_example', orient := 'genotype', genotypes := 'auto') LIMIT 1;
----
TINYINT

# ===================================================================
# genotypes × projection pushdown
# ===================================================================

# Metadata-only query with genotypes := 'list' — no PgrGet needed
query TI
SELECT CHROM, POS FROM read_pfile('test/data/pfile_example', genotypes := 'list') ORDER BY CHROM, POS;
----
1	10000
1	20000
1	30000
2	15000

# ===================================================================
# Multi-batch (large_example: 3000 variants × 8 samples)
# ===================================================================

# LIST lengths all consistent
query I
SELECT COUNT(DISTINCT len(genotypes)) FROM read_pfile('test/data/large_example',
    pgen := 'test/data/large_example.pgen',
    pvar := 'test/data/large_example.pvar',
    psam := 'test/data/large_example.psam',
    genotypes := 'list');
----
1

query I
SELECT MIN(len(genotypes)) FROM read_pfile('test/data/large_example',
    pgen := 'test/data/large_example.pgen',
    pvar := 'test/data/large_example.pvar',
    psam := 'test/data/large_example.psam',
    genotypes := 'list');
----
8

query I
SELECT COUNT(*) FROM read_pfile('test/data/large_example',
    pgen := 'test/data/large_example.pgen',
    pvar := 'test/data/large_example.pvar',
    psam := 'test/data/large_example.psam',
    genotypes := 'list');
----
3000

# ARRAY vs LIST equivalence on large dataset
query I
SELECT COUNT(*) FROM (
    SELECT a.ID, a.genotypes::TINYINT[] AS a_geno, l.genotypes AS l_geno
    FROM read_pfile('test/data/large_example',
        pgen := 'test/data/large_example.pgen',
        pvar := 'test/data/large_example.pvar',
        psam := 'test/data/large_example.psam',
        genotypes := 'array') a
    JOIN read_pfile('test/data/large_example',
        pgen := 'test/data/large_example.pgen',
        pvar := 'test/data/large_example.pvar',
        psam := 'test/data/large_example.psam',
        genotypes := 'list') l ON a.ID = l.ID
    WHERE a_geno != l_geno OR (a_geno IS NULL AND l_geno IS NOT NULL) OR (a_geno IS NOT NULL AND l_geno IS NULL)
);
----
0
